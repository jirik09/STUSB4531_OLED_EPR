################################################################################
# makefile.defs  –  persistent USBX additions (NOT auto-generated, IDE-safe)
#
# Included by Debug/makefile AFTER objects.mk, so USER_OBJS can be appended to
# without being wiped. All USBX sources are compiled here and fed to the linker
# via $(USER_OBJS).
################################################################################

# --------------------------------------------------------------------------- #
#  Common compiler flags for USBX files                                       #
# --------------------------------------------------------------------------- #
UX_CC      := arm-none-eabi-gcc
UX_CFLAGS  := -mcpu=cortex-m0plus -std=gnu11 \
               -DUSE_HAL_DRIVER -DSTM32C071xx \
               -DUX_INCLUDE_USER_DEFINE_FILE \
               -c -Os -ffunction-sections -fdata-sections \
               --specs=nano.specs -mfloat-abi=soft -mthumb \
               -MMD -MP

UX_INC     := -I../Core/Inc \
               -I../USBX/App \
               -I../USBX/Target \
               -I../Middlewares/ST/usbx/common/core/inc \
               -I../Middlewares/ST/usbx/common/usbx_device_classes/inc \
               -I../Middlewares/ST/usbx/common/usbx_stm32_device_controllers \
               -I../Middlewares/ST/usbx/ports/generic/inc \
               -I../Drivers/STM32C0xx_HAL_Driver/Inc \
               -I../Drivers/STM32C0xx_HAL_Driver/Inc/Legacy \
               -I../Drivers/CMSIS/Device/ST/STM32C0xx/Include \
               -I../Drivers/CMSIS/Include \
               -I../Drivers/OLED \
               -I../Drivers/STUSB4531

# --------------------------------------------------------------------------- #
#  Source file lists (relative to the Debug/ working directory)               #
# --------------------------------------------------------------------------- #
UX_APP_SRCS := \
  ../USBX/App/app_usbx_device.c \
  ../USBX/App/ux_device_cdc_acm.c \
  ../USBX/App/ux_device_descriptors.c

UX_CORE_SRCS := $(wildcard ../Middlewares/ST/usbx/common/core/src/*.c)

UX_CDC_SRCS  := $(wildcard ../Middlewares/ST/usbx/common/usbx_device_classes/src/*.c)

UX_DCD_SRCS  := $(wildcard ../Middlewares/ST/usbx/common/usbx_stm32_device_controllers/*.c)

UX_ALL_SRCS  := $(UX_APP_SRCS) $(UX_CORE_SRCS) $(UX_CDC_SRCS) $(UX_DCD_SRCS)

# --------------------------------------------------------------------------- #
#  Object file paths (mirror the source tree under Debug/)                    #
# --------------------------------------------------------------------------- #
UX_ALL_OBJS  := $(patsubst ../%,%, $(UX_ALL_SRCS:.c=.o))
UX_ALL_DEPS  := $(UX_ALL_OBJS:.o=.d)

# Append to USER_OBJS so the linker picks them up
USER_OBJS += $(UX_ALL_OBJS)

# Include auto-generated dependency files if present
-include $(UX_ALL_DEPS)

# --------------------------------------------------------------------------- #
#  Build rules                                                                 #
# --------------------------------------------------------------------------- #
USBX/App/%.o: ../USBX/App/%.c
	@mkdir -p $(dir $@)
	$(UX_CC) $(UX_CFLAGS) $(UX_INC) -MF"$(@:.o=.d)" -MT"$@" "$<" -o "$@"

Middlewares/ST/usbx/common/core/src/%.o: \
    ../Middlewares/ST/usbx/common/core/src/%.c
	@mkdir -p $(dir $@)
	$(UX_CC) $(UX_CFLAGS) $(UX_INC) -MF"$(@:.o=.d)" -MT"$@" "$<" -o "$@"

Middlewares/ST/usbx/common/usbx_device_classes/src/%.o: \
    ../Middlewares/ST/usbx/common/usbx_device_classes/src/%.c
	@mkdir -p $(dir $@)
	$(UX_CC) $(UX_CFLAGS) $(UX_INC) -MF"$(@:.o=.d)" -MT"$@" "$<" -o "$@"

Middlewares/ST/usbx/common/usbx_stm32_device_controllers/%.o: \
    ../Middlewares/ST/usbx/common/usbx_stm32_device_controllers/%.c
	@mkdir -p $(dir $@)
	$(UX_CC) $(UX_CFLAGS) $(UX_INC) -MF"$(@:.o=.d)" -MT"$@" "$<" -o "$@"
